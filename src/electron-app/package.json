{
  "name": "sistema-gvp",
  "version": "2.0.0",
  "description": "Sistema GVP - Punto de Venta",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:check": "node -e \"try{require('electron');console.log('Electron OK')}catch(e){console.log('Electron no instalado. Ejecute: npm install electron@latest --save-dev')}\"",
    "electron:build": "npm run build && electron-builder",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-table": "^8.20.0",
    "axios": "^1.7.0",
    "clsx": "^2.1.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.52.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^2.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "allowScripts": {
    "electron@30.5.1": true
  }
}

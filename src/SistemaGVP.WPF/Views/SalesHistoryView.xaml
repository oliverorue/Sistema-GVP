<UserControl x:Class="SistemaGVP.WPF.Views.SalesHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SistemaGVP.WPF.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SalesHistoryViewModel}"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ========== CABECERA ========== -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource PrimaryBrush}">
                <TextBlock Text="&#x1F4CA;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="Historial de Ventas" Style="{StaticResource Heading2Style}" />
                <TextBlock Text="Consulta y gestión de ventas realizadas" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- ========== FILTROS ========== -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}" Padding="16,12"
                Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource InputBgBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Height="32"
                            Width="220"
                            Margin="0,0,16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="13"
                                       VerticalAlignment="Center" Margin="8,0,4,0" Opacity="0.4" />
                            <TextBox Grid.Column="1" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource IconInputStyle}" VerticalAlignment="Stretch"
                                     ToolTip="Buscar por factura o cliente..." />
                        </Grid>
                    </Border>

                    <TextBlock Grid.Column="1" Text="Desde:" VerticalAlignment="Center"
                               FontSize="13" FontWeight="Medium" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <DatePicker Grid.Column="2" SelectedDate="{Binding StartDate}"
                                Width="140" Margin="0,0,16,0" Height="32" />

                    <TextBlock Grid.Column="3" Text="Hasta:" VerticalAlignment="Center"
                               FontSize="13" FontWeight="Medium" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <DatePicker Grid.Column="4" SelectedDate="{Binding EndDate}"
                                Width="140" Margin="0,0,16,0" Height="32" />

                    <Button Grid.Column="5" Content="&#x1F50D; Buscar"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" Height="32"
                            FontSize="12" Padding="12,4" Margin="0,0,8,0" />

                    <Button Grid.Column="6" Content="&#x2715; Limpiar"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Height="32"
                            FontSize="12" Padding="12,4" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========== DATAGRID ========== -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
        <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                  AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                  AlternationCount="2" SelectionMode="Single"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}"
                                    Width="130" />
                <DataGridTextColumn Header="Factura" Binding="{Binding InvoiceNumber}" Width="120" />
                <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="*" />
                <DataGridTextColumn Header="Total" Binding="{Binding Total, Converter={StaticResource CurrencyConverter}}"
                                    Width="120" />
                <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="100" />
                <DataGridTemplateColumn Header="Acciones" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="&#x1F50D;"
                                    Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonStyle}"
                                    FontSize="13" Padding="6,2" MinWidth="32"
                                    HorizontalAlignment="Center"
                                    ToolTipService.ToolTip="Ver detalle" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </Border>

        <!-- ========== PAGINACIÓN ========== -->
        <Border Grid.Row="3"
                Padding="14,10"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12"
                Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="&#x25C0; Anterior"
                        Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="32" FontSize="12" Padding="12,4"
                        Visibility="{Binding HasPreviousPage, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding PageInfo}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
                <Button Grid.Column="2"
                        Content="Siguiente &#x25B6;"
                        Command="{Binding NextPageCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="32" FontSize="12" Padding="12,4"
                        Visibility="{Binding HasNextPage, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Border>

        <!-- ========== LOADING OVERLAY ========== -->
        <Border Grid.RowSpan="4"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="{DynamicResource OverlayBgBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="6"
                             Margin="0,0,0,12"
                             Foreground="{DynamicResource PrimaryBrush}"
                             Background="{DynamicResource SurfaceBrush}" />
                <TextBlock Text="Cargando ventas..."
                           FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ========== DETALLE OVERLAY ========== -->
        <Border Grid.RowSpan="4"
                Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="{DynamicResource OverlayBgBrush}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="24"
                    MinWidth="500" MaxWidth="700" MaxHeight="500">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header del detalle -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Style="{StaticResource Heading2Style}" Margin="0,0,0,4">
                            <Run Text="&#x1F4CB; Detalle de Venta" />
                            <Run Text="#" />
                            <Run Text="{Binding SelectedSale.InvoiceNumber}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodySmallStyle}"
                                   Foreground="{DynamicResource TextMutedBrush}">
                            <Run Text="Cliente: " />
                            <Run Text="{Binding SelectedSale.CustomerName}" />
                            <Run Text=" — " />
                            <Run Text="{Binding SelectedSale.CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- DataGrid de detalles -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding SaleDetails}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              MaxHeight="300" Margin="0,0,0,16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Producto" Binding="{Binding ProductName}" Width="*" />
                            <DataGridTextColumn Header="Cantidad" Binding="{Binding Quantity, StringFormat=N2}" Width="80" />
                            <DataGridTextColumn Header="Precio" Binding="{Binding UnitPrice, Converter={StaticResource CurrencyConverter}}" Width="100" />
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, Converter={StaticResource CurrencyConverter}}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Botón cerrar -->
                    <Button Grid.Row="2" Content="&#x274C; Cerrar"
                            Command="{Binding CloseDetailCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="38" MinWidth="120" HorizontalAlignment="Right" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>

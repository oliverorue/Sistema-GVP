<UserControl x:Class="SistemaGVP.WPF.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SistemaGVP.WPF.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:SistemaGVP.WPF.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ProductsViewModel}"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ========== CABECERA ========== -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource PrimaryBrush}">
                <TextBlock Text="📦" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="Productos" Style="{StaticResource Heading2Style}" />
                <TextBlock Text="Gestión de productos y stock" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <Button Content="➡ Nuevo Producto"
                    Command="{Binding NewProductCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Height="36" Margin="24,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <!-- ========== BARRA DE BÚSQUEDA Y ACCIONES ========== -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}" Padding="12,8"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <!-- Search box with icon -->
                <Border Grid.Column="0"
                        Background="{DynamicResource InputBgBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Height="34" Width="280">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                                   VerticalAlignment="Center" Margin="10,0,6,0" Opacity="0.4" />
                        <TextBox Grid.Column="1" Text="{Binding SearchTerm}"
                                 Style="{StaticResource IconInputStyle}" VerticalAlignment="Stretch" />
                    </Grid>
                </Border>
                <Button Grid.Column="1" Content="Buscar" Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Height="34"
                        FontSize="12" Padding="12,4" Margin="8,0,4,0" />
                <Button Grid.Column="2" Content="🏷️ Etiquetas" Command="{Binding ShowBarcodeLabelsCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Height="34"
                        FontSize="12" Padding="12,4" Margin="0,0,4,0"
                        ToolTipService.ToolTip="Ver etiquetas de códigos de barras para imprimir" />
                <Button Grid.Column="3" Content="🔁 Generar Todos" Command="{Binding GenerateBarcodesForAllCommand}"
                        Style="{StaticResource DangerButtonStyle}" Height="34"
                        FontSize="12" Padding="12,4" HorizontalAlignment="Right"
                        ToolTipService.ToolTip="Generar códigos de barras para productos que no tengan" />
            </Grid>
        </Border>

        <!-- ========== MENSAJES DE ESTADO ========== -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}"
                           Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                           FontSize="13"
                           Foreground="{DynamicResource SuccessBrush}" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                           FontSize="13"
                           Foreground="{DynamicResource DangerBrush}" />
            </StackPanel>
        </Border>

        <!-- ========== DATAGRID DE PRODUCTOS ========== -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
        <DataGrid
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                  AlternationCount="2"
                  Margin="0,0,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="CÃ³digo" Binding="{Binding Barcode}" Width="110" />
                <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="2*" FontWeight="SemiBold" />
                <DataGridTextColumn Header="CategorÃ­a" Binding="{Binding CategoryName}" Width="100" />
                <DataGridTemplateColumn Header="Costo (Compra)" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Cost, StringFormat=Gs. {0:N0}}"
                                       HorizontalAlignment="Right" Margin="0,0,12,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13.5" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Precio (Venta)" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Price, StringFormat=Gs. {0:N0}}"
                                       HorizontalAlignment="Right" Margin="0,0,12,0"
                                       FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"
                                       FontSize="13.5" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Stock" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- Stock badge coloreado segÃºn nivel (verde â†’ amarillo â†’ rojo) -->
                            <Border CornerRadius="10" Padding="8,3"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Background="{Binding CurrentStock, Converter={StaticResource StockToColorConverter}}">
                                <TextBlock Text="{Binding CurrentStock}" FontSize="12"
                                           FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Unidad" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Unit}" Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="13.5" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Acciones" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Content="âœï¸"
                                        Command="{Binding DataContext.EditProductCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="13" Padding="8,4" MinWidth="36"
                                        ToolTipService.ToolTip="Editar producto" Margin="0,0,4,0" />
                                <Button Content="ðŸ—‘ï¸"
                                        Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="13" Padding="8,4" MinWidth="36"
                                        ToolTipService.ToolTip="Eliminar producto" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </Border>

        <!-- ========== PAGINACIÓN ========== -->
        <Border Grid.Row="4"
                Padding="14,10"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12"
                Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="← Anterior"
                        Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="32" FontSize="12" Padding="12,4"
                        Visibility="{Binding HasPreviousPage, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding PaginationText}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
                <Button Grid.Column="2"
                        Content="Siguiente →"
                        Command="{Binding NextPageCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="32" FontSize="12" Padding="12,4"
                        Visibility="{Binding HasNextPage, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Border>

        <!-- ============================================================
             OVERLAY DE EDICIÃ“N
             ============================================================ -->
        <Border Grid.RowSpan="5"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="{DynamicResource OverlayBgBrush}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="24"
                    MaxWidth="600" MaxHeight="700">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="âœï¸" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Nuevo Producto" Style="{StaticResource Heading2Style}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Error -->
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                                   TextWrapping="Wrap" FontWeight="Medium"
                                   Margin="0,0,0,8" />

                        <!-- Nombre -->
                        <TextBlock Text="Nombre" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingProduct.Name}" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,12" />

                        <!-- DescripciÃ³n -->
                        <TextBlock Text="DescripciÃ³n" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingProduct.Description}" Style="{StaticResource PremiumTextBoxStyle}"
                                 Height="60" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,12" />

                        <!-- CÃ³digo de Barras -->
                        <TextBlock Text="CÃ³digo de Barras" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding EditingProduct.Barcode}" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,8,0" />
                            <Button Grid.Column="1" Content="ðŸŽ² Generar" Command="{Binding GenerateBarcodeCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Height="40" VerticalAlignment="Center" Padding="10,0"
                                    ToolTipService.ToolTip="Generar cÃ³digo de barras automÃ¡tico" />
                        </Grid>

                        <!-- SKU -->
                        <TextBlock Text="SKU" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingProduct.Sku}" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,12" />

                        <!-- CategorÃ­a -->
                        <TextBlock Text="CategorÃ­a" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,0,12" Height="36" />

                        <!-- Precio y Costo -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Precio" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditingProduct.Price}" Style="{StaticResource PremiumTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Costo" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditingProduct.Cost}" Style="{StaticResource PremiumTextBoxStyle}" />
                            </StackPanel>
                        </Grid>

                        <!-- Stock MÃ­nimo y Unidad -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Stock MÃ­nimo" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditingProduct.MinStock}" Style="{StaticResource PremiumTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Unidad" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditingProduct.Unit}" Style="{StaticResource PremiumTextBoxStyle}" />
                            </StackPanel>
                        </Grid>

                        <!-- Activo -->
                        <CheckBox IsChecked="{Binding EditingProduct.IsActive}" Content="Producto activo" Margin="0,0,0,16" />

                        <!-- Footer -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="âŒ Cancelar" Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Height="38" MinWidth="120" Margin="0,0,8,0" />
                            <Button Content="ðŸ’¾ Guardar" Command="{Binding SaveProductCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" Height="38" MinWidth="120" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>



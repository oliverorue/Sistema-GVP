<UserControl x:Class="SistemaGVP.WPF.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SistemaGVP.WPF.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:SistemaGVP.WPF.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SuppliersViewModel}"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ========== CABECERA ========== -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource PrimaryBrush}">
                <TextBlock Text="🏭" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="Proveedores" Style="{StaticResource Heading2Style}" />
                <TextBlock Text="Gestión de proveedores" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <Button Content="➕ Nuevo Proveedor" Command="{Binding NewSupplierCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Height="36"
                    Margin="24,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <!-- ========== BARRA DE BÚSQUEDA ========== -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}" Padding="12,8"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{DynamicResource InputBgBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Height="34" Width="280">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                                   VerticalAlignment="Center" Margin="10,0,6,0" Opacity="0.4" />
                        <TextBox Grid.Column="1" Text="{Binding SearchTerm}"
                                 Style="{StaticResource IconInputStyle}" VerticalAlignment="Stretch" />
                        <Button Grid.Column="2" Content="Buscar" Command="{Binding SearchCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Height="28"
                                FontSize="11" Padding="10,2" Margin="4,0,4,0" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ========== TABLA DE PROVEEDORES ========== -->
        <Grid Grid.Row="2">
            <StackPanel VerticalAlignment="Top" Margin="0,0,0,8">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SuccessBrush}"
                           Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource DangerBrush}"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,8,0,0">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" Margin="0"
                      AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                      AlternationCount="2"
                      Style="{StaticResource DataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" FontWeight="SemiBold" Width="*" />
                    <DataGridTextColumn Header="RUC" Binding="{Binding TaxId}" Width="130" />
                    <DataGridTextColumn Header="Teléfono" Binding="{Binding Phone}" Width="130" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                    <DataGridTextColumn Header="DirecciÃ³n" Binding="{Binding Address}" Width="2*" />
                    <DataGridTemplateColumn Header="Acciones" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="âœï¸"
                                            Command="{Binding DataContext.EditSupplierCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}"
                                            FontSize="13" Padding="8,4" MinWidth="36"
                                            ToolTipService.ToolTip="Editar proveedor" Margin="0,0,4,0" />
                                    <Button Content="ðŸ—‘ï¸"
                                            Command="{Binding DataContext.DeleteSupplierCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}"
                                            FontSize="13" Padding="8,4" MinWidth="36"
                                            ToolTipService.ToolTip="Eliminar proveedor" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            </Border>
        </Grid>

        <!-- ============================================================
             OVERLAY DE EDICIÃ“N
             ============================================================ -->
        <Border Grid.RowSpan="3"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="{DynamicResource OverlayBgBrush}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="24"
                    MaxWidth="550">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="ðŸ­" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Proveedor" Style="{StaticResource Heading2Style}" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                                   TextWrapping="Wrap" FontWeight="Medium" Margin="0,0,0,8" />

                        <TextBlock Text="Nombre" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingSupplier.Name}" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,12" />

                        <TextBlock Text="Contacto" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingSupplier.ContactName}" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="RUC" FontSize="13" FontWeight="Medium"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditingSupplier.TaxId}" Style="{StaticResource PremiumTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="TelÃ©fono" FontSize="13" FontWeight="Medium"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditingSupplier.Phone}" Style="{StaticResource PremiumTextBoxStyle}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Email" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingSupplier.Email}" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,12" />

                        <TextBlock Text="DirecciÃ³n" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingSupplier.Address}" Style="{StaticResource PremiumTextBoxStyle}"
                                 Height="60" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,12" />

                        <CheckBox IsChecked="{Binding EditingSupplier.IsActive}" Content="Proveedor activo" Margin="0,0,0,16" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="âŒ Cancelar" Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Height="38" MinWidth="120" Margin="0,0,8,0" />
                            <Button Content="ðŸ’¾ Guardar" Command="{Binding SaveSupplierCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" Height="38" MinWidth="120" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>


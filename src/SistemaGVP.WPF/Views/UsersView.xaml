<UserControl x:Class="SistemaGVP.WPF.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SistemaGVP.WPF.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:SistemaGVP.WPF.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:UsersViewModel}"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ========== CABECERA ========== -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource PrimaryBrush}">
                <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="Usuarios" Style="{StaticResource Heading2Style}" />
                <TextBlock Text="Administración de usuarios del sistema" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <Button Content="➕ Nuevo Usuario" Command="{Binding NewUserCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Height="36"
                    Margin="24,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <!-- ========== BARRA DE BÚSQUEDA ========== -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}" Padding="12,8"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{DynamicResource InputBgBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Height="34" Width="280">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                                   VerticalAlignment="Center" Margin="10,0,6,0" Opacity="0.4" />
                        <TextBox Grid.Column="1" Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource IconInputStyle}" VerticalAlignment="Stretch" />
                        <Button Grid.Column="2" Content="Buscar" Command="{Binding SearchCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Height="28"
                                FontSize="11" Padding="10,2" Margin="4,0,4,0" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ========== MENSAJES ========== -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource SuccessBrush}"
                       Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}" />
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource DangerBrush}"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- ========== DATAGRID ========== -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
        <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                  AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                  AlternationCount="2"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Usuario" Binding="{Binding Username}"
                                    FontWeight="SemiBold" Width="120" />
                <DataGridTextColumn Header="Nombre Completo" Binding="{Binding FullName}" Width="*" />
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                <DataGridTextColumn Header="Rol" Binding="{Binding Role}" Width="90" />
                <DataGridTemplateColumn Header="Activo" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Ãšltimo Login" Binding="{Binding LastLogin, StringFormat=dd/MM/yyyy HH:mm}"
                                    Width="140" />
                <DataGridTemplateColumn Header="Acciones" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="âœï¸"
                                        Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="13" Padding="8,4" MinWidth="36"
                                        ToolTipService.ToolTip="Editar usuario" Margin="0,0,4,0" />
                                <Button Content="ðŸ—‘ï¸"
                                        Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="13" Padding="8,4" MinWidth="36"
                                        ToolTipService.ToolTip="Eliminar usuario" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </Border>

        <!-- ========== PAGINACIÓN ========== -->
        <Border Grid.Row="4"
                Padding="14,10"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12"
                Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="â† Anterior"
                        Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="32" FontSize="12" Padding="12,4"
                        Visibility="{Binding HasPreviousPage, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Grid.Column="1" Text="{Binding PaginationText}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
                <Button Grid.Column="2" Content="Siguiente â†’"
                        Command="{Binding NextPageCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="32" FontSize="12" Padding="12,4"
                        Visibility="{Binding HasNextPage, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Border>

        <!-- ========== OVERLAY DE EDICIÃ“N ========== -->
        <Border Grid.RowSpan="5"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="{DynamicResource OverlayBgBrush}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="24"
                    MaxWidth="500">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="ðŸ‘¤" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Style="{StaticResource Heading2Style}" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                                   TextWrapping="Wrap" FontWeight="Medium" Margin="0,0,0,8" />

                        <TextBlock Text="Nombre de Usuario" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingUser.Username}"
                                 Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,12" />

                        <TextBlock Text="Nombre Completo" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingUser.FullName}"
                                 Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,12" />

                        <TextBlock Text="Email" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingUser.Email}"
                                 Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,12" />

                        <TextBlock Text="ContraseÃ±a" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <PasswordBox x:Name="UserPasswordBox"
                                      Style="{StaticResource PremiumPasswordBoxStyle}" Margin="0,0,0,4"
                                      controls:PasswordBoxHelper.IsMonitoring="True"
                                      controls:PasswordBoxHelper.BoundPassword="{Binding EditingPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      controls:PasswordBoxHelper.SecurePassword="{Binding SecureEditingPassword, Mode=OneWayToSource}" />
                        <TextBlock Text="Dejar vacÃ­o para no cambiar" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,12"
                                   Visibility="{Binding IsNew, Converter={StaticResource InverseBoolConverter}}" />

                        <TextBlock Text="Rol" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{x:Static vm:UsersViewModel.RoleOptions}"
                                  SelectedItem="{Binding EditingUser.Role}"
                                  Margin="0,0,0,12" Height="36" />

                        <CheckBox IsChecked="{Binding EditingUser.IsActive}"
                                  Content="Usuario activo" Margin="0,0,0,8" />
                        <CheckBox IsChecked="{Binding EditingUser.MustChangePassword}"
                                  Content="Debe cambiar contraseÃ±a al ingresar" Margin="0,0,0,16" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="âŒ Cancelar" Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="38" MinWidth="120" Margin="0,0,8,0" />
                            <Button Content="ðŸ’¾ Guardar" Command="{Binding SaveUserCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Height="38" MinWidth="120" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>


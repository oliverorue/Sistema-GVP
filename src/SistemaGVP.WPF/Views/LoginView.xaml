<UserControl x:Class="SistemaGVP.WPF.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:controls="clr-namespace:SistemaGVP.WPF.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SistemaGVP.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:LoginViewModel}">

    <UserControl.Resources>
        <DrawingBrush x:Key="GridPatternBrush"
                      Viewport="0,0,40,40"
                      ViewportUnits="Absolute"
                      TileMode="Tile">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Geometry="M 20,0 L 20,40">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#E2E8F0" Thickness="1" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                    <GeometryDrawing Geometry="M 0,20 L 40,20">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#E2E8F0" Thickness="1" />
                        </GeometryDrawing.Pen>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Storyboard x:Key="ErrorFadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                From="0,-6,0,0" To="0,4,0,0"
                                Duration="0:0:0.35">
                <ThicknessAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <Style x:Key="LoginLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnSurfaceVariantBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="LoginInputContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource LoginSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource OutlineVariantBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Height" Value="48" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LoginInputStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="LoginPasswordInputStyle" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="LoginTogglePasswordStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceContainerLowBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="50" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <ContentPresenter x:Name="ContentPresenter"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource PrimaryDarkBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoNoticeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PrimaryFixedBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Opacity" Value="0.95" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              Width="480"
              Background="{DynamicResource LoginSurfaceBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="440"
                            Margin="32,48"
                            HorizontalAlignment="Center">

                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,32">
                        <Border Width="40" Height="40"
                                CornerRadius="10"
                                Background="{DynamicResource PrimaryContainerBrush}"
                                Margin="0,0,14,0">
                            <iconPacks:PackIconMaterial Kind="ShieldAccount"
                                                              FontSize="20"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Foreground="White" />
                        </Border>
                        <TextBlock Text="SistemaGVP"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="Bienvenido"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Ingresá tus credenciales para acceder al sistema"
                               FontSize="14"
                               Foreground="{DynamicResource OutlineBrush}"
                               Margin="0,0,0,32" />

                    <TextBlock Text="USUARIO"
                               Style="{StaticResource LoginLabelStyle}" />
                    <Border Style="{StaticResource LoginInputContainerStyle}"
                            Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <iconPacks:PackIconMaterial Grid.Column="0"
                                                               Kind="Account"
                                                               FontSize="18"
                                                               VerticalAlignment="Center"
                                                               Margin="14,0,10,0"
                                                               Foreground="{DynamicResource OutlineBrush}" />

                            <TextBox Grid.Column="1"
                                     x:Name="UsernameBox"
                                     Text="{Binding Username}"
                                     Style="{StaticResource LoginInputStyle}"
                                     ToolTip="Ingresá tu usuario" />
                        </Grid>
                    </Border>

                    <TextBlock Text="CONTRASEÑA"
                               Style="{StaticResource LoginLabelStyle}" />
                    <Border Style="{StaticResource LoginInputContainerStyle}"
                            Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <iconPacks:PackIconMaterial Grid.Column="0"
                                                               Kind="Lock"
                                                               FontSize="18"
                                                               VerticalAlignment="Center"
                                                               Margin="14,0,10,0"
                                                               Foreground="{DynamicResource OutlineBrush}" />

                            <PasswordBox Grid.Column="1"
                                         x:Name="PasswordBox"
                                         Style="{StaticResource LoginPasswordInputStyle}"
                                         VerticalAlignment="Stretch"
                                         controls:PasswordBoxHelper.IsMonitoring="True"
                                         controls:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         controls:PasswordBoxHelper.SecurePassword="{Binding SecurePassword, Mode=OneWayToSource}"
                                         Visibility="{Binding ShowPassword, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                            <TextBox Grid.Column="1"
                                     x:Name="PasswordVisibleBox"
                                     Text="{Binding Password}"
                                     Style="{StaticResource LoginInputStyle}"
                                     VerticalAlignment="Stretch"
                                     Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <ToggleButton Grid.Column="2"
                                          x:Name="TogglePasswordBtn"
                                          IsChecked="{Binding ShowPassword}"
                                          Style="{StaticResource LoginTogglePasswordStyle}"
                                          ToolTipService.ToolTip="Mostrar contraseña">
                                <iconPacks:PackIconMaterial x:Name="TogglePasswordIcon"
                                                                   Kind="Eye"
                                                                   FontSize="18"
                                                                   Foreground="{DynamicResource OutlineBrush}" />
                            </ToggleButton>
                        </Grid>
                    </Border>

                    <Border Height="40"
                            Margin="0,0,0,8"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Border.Loaded">
                                <BeginStoryboard Storyboard="{StaticResource ErrorFadeInAnimation}" />
                            </EventTrigger>
                        </Border.Triggers>
                        <Border Background="{DynamicResource AlertDangerBgBrush}"
                                CornerRadius="8"
                                Padding="12,10"
                                Height="36"
                                VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <iconPacks:PackIconMaterial Grid.Column="0"
                                                                   Kind="Alert"
                                                                   FontSize="14"
                                                                   Margin="0,0,8,0"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource DangerBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ErrorMessage}"
                                           FontSize="12"
                                           Foreground="{DynamicResource DangerBrush}"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </Border>

                    <Border Style="{StaticResource InfoNoticeStyle}"
                            Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Grid.Column="0"
                                                               Kind="Information"
                                                               FontSize="16"
                                                               Margin="0,2,10,0"
                                                               VerticalAlignment="Top"
                                                               Foreground="{DynamicResource PrimaryBrush}" />
                            <TextBlock Grid.Column="1"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="{DynamicResource OnPrimaryFixedVariantBrush}"
                                       LineHeight="16">
                                El acceso está restringido al personal autorizado. La actividad de la sesión se registra para auditoría de seguridad.
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Button Content="INGRESAR AL SISTEMA"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource LoginButtonStyle}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Margin="0,8,0,0"
                                 Height="3"
                                 Foreground="{DynamicResource PrimaryBrush}" />

                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="{DynamicResource SurfaceAltBrush}"
                            Padding="16,10"
                            Margin="0,32,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Grid.Column="0"
                                                               Kind="ShieldCheck"
                                                               FontSize="14"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SuccessBrush}"
                                                               Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1"
                                       Text="Conexión Encriptada 256-bit"
                                       FontSize="12"
                                       Foreground="{DynamicResource OutlineBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,20,0,0">
                        <TextBlock Text="v24.1.0-ESTABLE"
                                   FontSize="11"
                                   Foreground="{DynamicResource OutlineBrush}" />
                        <Ellipse Width="4" Height="4"
                                 Fill="{DynamicResource OutlineVariantBrush}"
                                 Margin="12,0"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="LATAM-S1 SERVER"
                                   FontSize="11"
                                   Foreground="{DynamicResource OutlineBrush}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="1"
              x:Name="BrandingPanel"
              Background="{DynamicResource LoginBrandBgBrush}">

            <Border Background="{StaticResource GridPatternBrush}"
                    Opacity="0.8" />

            <Border Width="500" Height="500"
                    CornerRadius="250"
                    Background="{DynamicResource PrimaryFixedBrush}"
                    Opacity="0.5"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-100,-100,0"
                    x:Name="Blob1">
                <Border.Effect>
                    <BlurEffect Radius="100" />
                </Border.Effect>
            </Border>

            <Border Width="400" Height="400"
                    CornerRadius="200"
                    Background="{DynamicResource SecondaryContainerBrush}"
                    Opacity="0.5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="-100,0,0,-80"
                    x:Name="Blob2">
                <Border.Effect>
                    <BlurEffect Radius="80" />
                </Border.Effect>
            </Border>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        ZIndex="10">
                <Border Width="96" Height="96"
                        CornerRadius="24"
                        Background="{DynamicResource PrimaryContainerBrush}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,32">
                    <iconPacks:PackIconMaterial Kind="ShieldAccount"
                                                      FontSize="48"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Foreground="White" />
                </Border>

                <TextBlock Text="SistemaGVP"
                           FontSize="48"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <TextBlock Text="PUERTA DE ENTRADA EMPRESARIAL"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextOnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
<UserControl x:Class="SistemaGVP.WPF.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:vm="clr-namespace:SistemaGVP.WPF.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SalesViewModel}"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <!-- ============================================================
             CAPA 1: CONTENIDO PRINCIPAL (Grid 3 columnas)
             ============================================================ -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- ============================================================
             COLUMNA 0 — PANEL IZQUIERDO: PRODUCTOS + CARRITO
             ============================================================ -->
        <Grid Grid.Column="0" Margin="16,16,8,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="250" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <iconPacks:PackIconMaterial Kind="Cart" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource PrimaryBrush}" />
                <TextBlock Text="Punto de Venta" Style="{StaticResource Heading1Style}" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Barra de búsqueda -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100"
                        Height="36"
                        Command="{Binding SearchProductsCommand}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Magnify" FontSize="14" Margin="0,0,6,0" />
                        <TextBlock Text="Buscar" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- DataGrid Resultados de búsqueda -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding SearchResults}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                      AlternationCount="2"
                      Style="{StaticResource DataGridStyle}"
                      Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVisibilityConverter}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding Barcode}"
                                        Width="120" />
                    <DataGridTextColumn Header="Producto"
                                        Binding="{Binding Name}"
                                        Width="*" />
                    <DataGridTextColumn Header="Precio"
                                        Binding="{Binding Price, Converter={StaticResource CurrencyConverter}}"
                                        Width="100" />
                    <DataGridTextColumn Header="Stock"
                                        Binding="{Binding CurrentStock}"
                                        Width="70" />
                    <DataGridTemplateColumn Header="Acción" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Height="30"
                                        FontSize="11">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="Plus" FontSize="11" Margin="0,0,4,0" />
                                        <TextBlock Text="Agregar" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty state búsqueda -->
            <Border Grid.Row="2"
                    Style="{StaticResource EmptyStateStyle}"
                    Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="Magnify" FontSize="12" Margin="0,0,6,0" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="Busque productos por código o nombre" Style="{StaticResource CaptionStyle}" />
                </StackPanel>
            </Border>

            <!-- Separador -->
            <Rectangle Grid.Row="3"
                       Height="1"
                       Fill="{DynamicResource BorderBrush}"
                       Margin="0,12,0,8" />

            <!-- Header Carrito -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="Receipt" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Carrito" Style="{StaticResource Heading3Style}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding TotalItems, StringFormat='{}{0} item(s)'}"
                           Style="{StaticResource CaptionStyle}"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- DataGrid Carrito -->
            <DataGrid Grid.Row="4"
                      ItemsSource="{Binding CartItems}"
                      SelectedItem="{Binding SelectedCartItem}"
                      AutoGenerateColumns="False"
                      AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                      AlternationCount="2"
                      Style="{StaticResource DataGridStyle}"
                      Margin="0,6,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto"
                                        Binding="{Binding ProductName}"
                                        Width="*" />
                    <DataGridTextColumn Header="Precio Unit."
                                        Binding="{Binding UnitPrice, Converter={StaticResource CurrencyConverter}}"
                                        Width="100" />
                    <DataGridTemplateColumn Header="Cantidad" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="28"
                                            Height="28">
                                        <iconPacks:PackIconMaterial Kind="Minus" FontSize="14" />
                                    </Button>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Quantity}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <Button Grid.Column="2"
                                            Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="28"
                                            Height="28">
                                        <iconPacks:PackIconMaterial Kind="Plus" FontSize="14" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Subtotal"
                                        Binding="{Binding Subtotal, Converter={StaticResource CurrencyConverter}}"
                                        Width="110" />
                    <DataGridTemplateColumn Header="" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="32"
                                        Height="32">
                                    <iconPacks:PackIconMaterial Kind="Delete" FontSize="14" />
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty state carrito -->
            <Border Grid.Row="4"
                    Style="{StaticResource EmptyStateStyle}"
                    Visibility="{Binding HasCartItems, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="Cart" FontSize="12" Margin="0,0,6,0" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="El carrito está vacío" Style="{StaticResource CaptionStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Separador vertical -->
        <Rectangle Grid.Column="1"
                   Width="1"
                   Fill="{DynamicResource BorderBrush}"
                   Margin="0,16" />

        <!-- ============================================================
             COLUMNA 2 — PANEL DERECHO: CLIENTE + TOTALES + BOTONES
             ============================================================ -->
        <ScrollViewer Grid.Column="2" Margin="8,16,16,16">
            <StackPanel>

                <!-- ════════ SECCIÓN CLIENTE ════════ -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12"
                        Padding="16"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <iconPacks:PackIconMaterial Kind="Account" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Cliente" Style="{StaticResource Heading3Style}" />
                        </StackPanel>

                        <StackPanel>
                            <Button Command="{Binding OpenCustomerPanelCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="36">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Account" FontSize="14" Margin="0,0,6,0" />
                                    <TextBlock Text="Seleccionar Cliente" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="{Binding SelectedCustomer.Name}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Style="{StaticResource CaptionStyle}">
                                <Run Text="RUC: " />
                                <Run Text="{Binding SelectedCustomer.TaxId}" />
                            </TextBlock>
                            <Button Command="{Binding OpenCustomerPanelCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Margin="0,6,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Pencil" FontSize="14" Margin="0,0,4,0" />
                                    <TextBlock Text="Cambiar Cliente" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ════════ SECCIÓN TOTALES ════════ -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12"
                        Padding="16"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <iconPacks:PackIconMaterial Kind="Cash" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Totales" Style="{StaticResource Heading3Style}" />
                        </StackPanel>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Subtotal -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Subtotal"
                                       Style="{StaticResource BodyStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Subtotal, Converter={StaticResource CurrencyConverter}}"
                                       Style="{StaticResource PriceDisplay}" />

                            <!-- IVA -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Style="{StaticResource BodyStyle}"
                                       Margin="0,4,0,0">
                                <Run Text="IVA" />
                                <Run Text="{Binding TaxRate, StringFormat=' ({0:P0})'}" />
                            </TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding TaxAmount, Converter={StaticResource CurrencyConverter}}"
                                       Style="{StaticResource PriceDisplay}"
                                       Margin="0,4,0,0" />

                            <!-- Separador -->
                            <Rectangle Grid.Row="2" Grid.ColumnSpan="2"
                                       Height="1"
                                       Fill="{DynamicResource BorderBrush}"
                                       Margin="0,8" />

                            <!-- TOTAL -->
                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="TOTAL"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" />
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding Total, Converter={StaticResource CurrencyConverter}}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" />
                        </Grid>

                        <TextBlock Text="{Binding TotalItems, StringFormat='Total items: {0}'}"
                                   Style="{StaticResource CaptionStyle}"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- ════════ BOTONES DE ACCIÓN ════════ -->
                <StackPanel Margin="0,0,0,12">
                    <!-- Botón Escáner Móvil -->
                    <ui:Button Command="{Binding ToggleScannerPanelCommand}"
                               Appearance="Caution"
                               Height="40"
                               Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Camera" FontSize="16" Margin="0,0,8,0" />
                            <TextBlock Text="Escáner Móvil" />
                        </StackPanel>
                    </ui:Button>

                    <ui:Button Command="{Binding HoldSaleCommand}"
                               Appearance="Secondary"
                               Height="40"
                               Margin="0,0,0,6"
                               IsEnabled="{Binding HasCartItems}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Pause" FontSize="16" Margin="0,0,8,0" />
                            <TextBlock Text="Poner en Espera" />
                        </StackPanel>
                    </ui:Button>

                    <ui:Button Command="{Binding ClearCartCommand}"
                               Appearance="Danger"
                               Height="40"
                               Margin="0,0,0,6"
                               IsEnabled="{Binding HasCartItems}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Delete" FontSize="16" Margin="0,0,8,0" />
                            <TextBlock Text="Vaciar Carrito" />
                        </StackPanel>
                    </ui:Button>

                    <ui:Button Command="{Binding OpenPaymentPanelCommand}"
                               Appearance="Success"
                               FontSize="18"
                               FontWeight="Bold"
                               Height="50"
                               Margin="0,0,0,6"
                               IsEnabled="{Binding HasCartItems}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Cash" FontSize="20" Margin="0,0,8,0" />
                            <TextBlock Text="Cobrar" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>

                <!-- ════════ VENTAS EN ESPERA ════════ -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12"
                        Padding="16"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <iconPacks:PackIconMaterial Kind="ClipboardText" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Ventas en Espera" Style="{StaticResource Heading3Style}" />
                        </StackPanel>

                        <Button Command="{Binding OpenHeldSalesPanelCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="36">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ClipboardText" FontSize="14" Margin="0,0,6,0" />
                                <TextBlock Text="Ver pendientes" Margin="0,0,8,0" />
                                <Border Background="{DynamicResource PrimaryBrush}"
                                        CornerRadius="10"
                                        Padding="6,2"
                                        Visibility="{Binding HasHeldSales, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding HeldSales.Count}"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ════════ LOADING OVERLAY ════════ -->
        <Border Grid.ColumnSpan="3"
                Background="{DynamicResource OverlayBgBrush}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="20">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True"
                                 Width="48"
                                 Height="48"
                                 Foreground="{DynamicResource PrimaryBrush}" />
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource BodyStyle}"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

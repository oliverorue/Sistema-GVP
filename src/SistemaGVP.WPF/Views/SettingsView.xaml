<UserControl x:Class="SistemaGVP.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SistemaGVP.WPF.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,20">
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource PrimaryBrush}">
                        <TextBlock Text="&#x2699;&#xFE0F;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="Configuración" Style="{StaticResource Heading2Style}" />
                        <TextBlock Text="Administra los datos fiscales y preferencias de tu empresa" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Form Card -->
                <Border Style="{StaticResource SectionPanelStyle}" MaxWidth="700"
                        HorizontalAlignment="Left" Padding="25">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Row 0: Nombre -->
                        <TextBlock Text="Nombre"
                                   Grid.Row="0" Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding EditingCompany.Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TextBoxStyle}"
                                 Margin="0,0,0,12" />

                        <!-- Row 1: RUC -->
                        <TextBlock Text="RUC"
                                   Grid.Row="1" Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding EditingCompany.TaxId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TextBoxStyle}"
                                 Margin="0,0,0,12" />

                        <!-- Row 2: Dirección -->
                        <TextBlock Text="Dirección"
                                   Grid.Row="2" Grid.Column="0"
                                   VerticalAlignment="Top"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding EditingCompany.Address, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TextBoxStyle}"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 Height="60"
                                 Margin="0,0,0,12" />

                        <!-- Row 3: Teléfono -->
                        <TextBlock Text="Teléfono"
                                   Grid.Row="3" Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding EditingCompany.Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TextBoxStyle}"
                                 Margin="0,0,0,12" />

                        <!-- Row 4: Email -->
                        <TextBlock Text="Email"
                                   Grid.Row="4" Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 Text="{Binding EditingCompany.Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TextBoxStyle}"
                                 Margin="0,0,0,12" />

                        <!-- Row 5: Tasa de Impuesto -->
                        <TextBlock Text="Tasa de Impuesto (%)"
                                   Grid.Row="5" Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="5" Grid.Column="1"
                                 Text="{Binding EditingCompany.TaxRate, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 Style="{StaticResource TextBoxStyle}"
                                 Margin="0,0,0,12" />

                        <!-- Row 6: Moneda -->
                        <TextBlock Text="Moneda"
                                   Grid.Row="6" Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="6" Grid.Column="1"
                                 Text="{Binding EditingCompany.Currency, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TextBoxStyle}"
                                 Margin="0,0,0,12" />

                        <!-- Row 7: Umbral Stock Bajo -->
                        <TextBlock Text="Umbral Stock Bajo"
                                   Grid.Row="7" Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox Grid.Row="7" Grid.Column="1"
                                 Text="{Binding EditingCompany.LowStockThreshold, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TextBoxStyle}"
                                 Margin="0,0,0,12" />

                        <!-- Row 8: Botón Guardar -->
                        <Button Grid.Row="8" Grid.Column="1"
                                Content="Guardar Cambios"
                                Command="{Binding SaveSettingsCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="150"
                                Height="40"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0" />
                    </Grid>
                </Border>

                <!-- Success Message -->
                <TextBlock Text="✓ Configuración guardada exitosamente"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SuccessBrush}"
                           Margin="0,16,0,0"
                           Visibility="{Binding IsSaved, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Background="{DynamicResource OverlayBgBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="200"
                             Height="4"
                             Foreground="{DynamicResource PrimaryBrush}"
                             Background="{DynamicResource BorderLightBrush}" />
                <TextBlock Text="Guardando..."
                           FontSize="16"
                           Foreground="White"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

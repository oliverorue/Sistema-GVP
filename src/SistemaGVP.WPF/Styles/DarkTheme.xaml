<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== TEMA OSCURO — Material 3 Inspired ===== -->

    <!-- Primary -->
    <Color x:Key="PrimaryColor">#3B82F6</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#60A5FA" />
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#1E3A5F" />
    <SolidColorBrush x:Key="PrimaryFixedBrush" Color="#d2e4ff" />
    <SolidColorBrush x:Key="OnPrimaryFixedVariantBrush" Color="#07497d" />
    <SolidColorBrush x:Key="AccentBrush" Color="#F59E0B" />

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#4ADE80" />
    <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24" />
    <SolidColorBrush x:Key="InfoBrush" Color="#38BDF8" />

    <!-- Surfaces -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#334155" />
    <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="#334155" />
    <SolidColorBrush x:Key="SurfaceBrightBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="LoginSurfaceBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="LoginBrandBgBrush" Color="#0F172A" />

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#F1F5F9</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F5F9" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="TextOnSurfaceVariantBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="TextSecondaryFixedVariantBrush" Color="#94A3B8" />

    <!-- Borders -->
    <Color x:Key="BorderColor">#334155</Color>
    <SolidColorBrush x:Key="BorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="OutlineBrush" Color="#64748B" />
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="#475569" />

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBgBrush" Color="#0D1B2E" />
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="SidebarFooterBgBrush" Color="#000000" />
    <SolidColorBrush x:Key="SidebarSectionTitleBrush" Color="#64748B" />

    <!-- TopBar -->
    <SolidColorBrush x:Key="TopBarBgBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="TopBarBorderBrush" Color="#334155" />

    <!-- Cards -->
    <SolidColorBrush x:Key="CardBlueBrush" Color="#1E3A5F" />
    <SolidColorBrush x:Key="CardOrangeBrush" Color="#7B241C" />
    <SolidColorBrush x:Key="CardGreenBrush" Color="#14532D" />
    <SolidColorBrush x:Key="CardTealBrush" Color="#134E4A" />
    <SolidColorBrush x:Key="CardRedBrush" Color="#7F1D1D" />
    <SolidColorBrush x:Key="CardPurpleBrush" Color="#3B0764" />

    <!-- DataGrid -->
    <SolidColorBrush x:Key="DataGridHeaderBgBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="DataGridHeaderFgBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="DataGridRowHoverBrush" Color="#3B4F6B" />
    <SolidColorBrush x:Key="DataGridRowSelectedBrush" Color="#1E3A6B" />
    <SolidColorBrush x:Key="DataGridRowAltBrush" Color="#1A2332" />

    <!-- Misc -->
    <SolidColorBrush x:Key="SkeletonBrush" Color="#334155" />
    <SolidColorBrush x:Key="OverlayBgBrush" Color="#CC000000" />
    <SolidColorBrush x:Key="CardBgBrush" Color="#334155" />
    <SolidColorBrush x:Key="InputBgBrush" Color="#0F172A" />

    <!-- Alert backgrounds -->
    <SolidColorBrush x:Key="AlertSuccessBgBrush" Color="#14532D" />
    <SolidColorBrush x:Key="AlertWarningBgBrush" Color="#713F12" />
    <SolidColorBrush x:Key="AlertDangerBgBrush" Color="#7F1D1D" />
    <SolidColorBrush x:Key="AlertInfoBgBrush" Color="#1E3A5F" />

    <!-- Card variants (semi-transparent for dark theme) -->
    <SolidColorBrush x:Key="CardBgDefaultBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="CardBgPrimaryBrush" Color="#1E3A5F" />
    <SolidColorBrush x:Key="CardBgSuccessBrush" Color="#14532D" />
    <SolidColorBrush x:Key="CardBgWarningBrush" Color="#422006" />
    <SolidColorBrush x:Key="CardBgDangerBrush" Color="#450A0A" />
    <SolidColorBrush x:Key="CardBgInfoBrush" Color="#0C4A6E" />

    <!-- Input backgrounds -->
    <SolidColorBrush x:Key="InputFocusedBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="InputErrorBrush" Color="#F87171" />

    <!-- Code/Highlight background -->
    <SolidColorBrush x:Key="HighlightBrush" Color="#3B82F6" />

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#475569" />
    <SolidColorBrush x:Key="ScrollbarTrackBrush" Color="#1E293B" />

    <!-- Tooltip -->
    <SolidColorBrush x:Key="TooltipBgBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="TooltipBorderBrush" Color="#475569" />
    <SolidColorBrush x:Key="TooltipTextBrush" Color="#F1F5F9" />

    <!-- Divider -->
    <SolidColorBrush x:Key="DividerBrush" Color="#334155" />
</ResourceDictionary>
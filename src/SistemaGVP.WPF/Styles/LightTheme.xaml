<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== TEMA CLARO — Material 3 Inspired ===== -->

    <!-- Primary -->
    <Color x:Key="PrimaryColor">#00355f</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#00355f" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#002244" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#0f4c81" />
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#0f4c81" />
    <SolidColorBrush x:Key="PrimaryFixedBrush" Color="#d2e4ff" />
    <SolidColorBrush x:Key="OnPrimaryFixedVariantBrush" Color="#07497d" />
    <SolidColorBrush x:Key="AccentBrush" Color="#F57C00" />

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" />
    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="InfoBrush" Color="#3B82F6" />

    <!-- Surfaces -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#f3f3f8" />
    <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#f3f3f8" />
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="#ededf3" />
    <SolidColorBrush x:Key="SurfaceBrightBrush" Color="#f9f9fe" />
    <SolidColorBrush x:Key="LoginSurfaceBrush" Color="#f9f9fe" />
    <SolidColorBrush x:Key="LoginBrandBgBrush" Color="#f3f3f8" />

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#191c1f</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#191c1f" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#42474f" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B" />
    <SolidColorBrush x:Key="TextInverseBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextOnSurfaceVariantBrush" Color="#42474f" />
    <SolidColorBrush x:Key="TextSecondaryFixedVariantBrush" Color="#3a485c" />

    <!-- Borders -->
    <Color x:Key="BorderColor">#E2E8F0</Color>
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="#F1F5F9" />
    <SolidColorBrush x:Key="OutlineBrush" Color="#727780" />
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="#c2c7d1" />

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBgBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="#00355f" />
    <SolidColorBrush x:Key="SidebarFooterBgBrush" Color="#020617" />
    <SolidColorBrush x:Key="SidebarSectionTitleBrush" Color="#475569" />

    <!-- TopBar -->
    <SolidColorBrush x:Key="TopBarBgBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TopBarBorderBrush" Color="#E2E8F0" />

    <!-- Cards -->
    <SolidColorBrush x:Key="CardBlueBrush" Color="#1E3A5F" />
    <SolidColorBrush x:Key="CardOrangeBrush" Color="#BF360C" />
    <SolidColorBrush x:Key="CardGreenBrush" Color="#1B5E20" />
    <SolidColorBrush x:Key="CardTealBrush" Color="#00695C" />
    <SolidColorBrush x:Key="CardRedBrush" Color="#B71C1C" />
    <SolidColorBrush x:Key="CardPurpleBrush" Color="#4A148C" />

    <!-- DataGrid -->
    <SolidColorBrush x:Key="DataGridHeaderBgBrush" Color="#F1F5F9" />
    <SolidColorBrush x:Key="DataGridHeaderFgBrush" Color="#475569" />
    <SolidColorBrush x:Key="DataGridRowHoverBrush" Color="#F1F5F9" />
    <SolidColorBrush x:Key="DataGridRowSelectedBrush" Color="#E3F2FD" />
    <SolidColorBrush x:Key="DataGridRowAltBrush" Color="#F8FAFC" />

    <!-- Misc -->
    <SolidColorBrush x:Key="SkeletonBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="OverlayBgBrush" Color="#80000000" />
    <SolidColorBrush x:Key="CardBgBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="InputBgBrush" Color="#F1F5F9" />

    <!-- Alert backgrounds -->
    <SolidColorBrush x:Key="AlertSuccessBgBrush" Color="#E8F5E9" />
    <SolidColorBrush x:Key="AlertWarningBgBrush" Color="#FFF8E1" />
    <SolidColorBrush x:Key="AlertDangerBgBrush" Color="#FFEBEE" />
    <SolidColorBrush x:Key="AlertInfoBgBrush" Color="#E3F2FD" />

    <!-- Card variants -->
    <SolidColorBrush x:Key="CardBgDefaultBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardBgPrimaryBrush" Color="#E3F2FD" />
    <SolidColorBrush x:Key="CardBgSuccessBrush" Color="#E8F5E9" />
    <SolidColorBrush x:Key="CardBgWarningBrush" Color="#FFF8E1" />
    <SolidColorBrush x:Key="CardBgDangerBrush" Color="#FFEBEE" />
    <SolidColorBrush x:Key="CardBgInfoBrush" Color="#E1F5FE" />

    <!-- Input backgrounds -->
    <SolidColorBrush x:Key="InputFocusedBrush" Color="#00355f" />
    <SolidColorBrush x:Key="InputErrorBrush" Color="#EF4444" />

    <!-- Code/Highlight background -->
    <SolidColorBrush x:Key="HighlightBrush" Color="#00355f" />

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#CBD5E1" />
    <SolidColorBrush x:Key="ScrollbarTrackBrush" Color="#F1F5F9" />

    <!-- Tooltip -->
    <SolidColorBrush x:Key="TooltipBgBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TooltipBorderBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="TooltipTextBrush" Color="#0F172A" />

    <!-- Divider -->
    <SolidColorBrush x:Key="DividerBrush" Color="#E2E8F0" />
</ResourceDictionary>
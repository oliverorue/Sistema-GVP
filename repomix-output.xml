                                Background="#66FFFFFF"
                                CornerRadius="2"
                                HorizontalAlignment="Center"
                                Margin="0,32,0,0" />

                        <!-- Feature list con iconos -->
                        <StackPanel Margin="0,32,0,0">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="✓" Foreground="#CCFFFFFF" FontSize="16"
                                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Gestión de ventas e inventario"
                                           Foreground="#99FFFFFF" FontSize="13" VerticalAlignment="Center" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="✓" Foreground="#CCFFFFFF" FontSize="16"
                                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Reportes y análisis en tiempo real"
                                           Foreground="#99FFFFFF" FontSize="13" VerticalAlignment="Center" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="✓" Foreground="#CCFFFFFF" FontSize="16"
                                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Soporte multi-usuario"
                                           Foreground="#99FFFFFF" FontSize="13" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Footer del panel izquierdo -->
                    <TextBlock Grid.Row="1"
                               Text="© 2025 GVP Solutions"
                               FontSize="12"
                               Foreground="#66FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,32" />
                </Grid>
            </Border>

            <!-- ============================================================
                 PANEL DERECHO: Formulario de inicio de sesión
                 ============================================================ -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="0,16,16,0"
                    MinHeight="520"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,1,1">
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="400"
                      Margin="48,32">

                    <StackPanel>

                        <!-- Título del formulario con icono decorativo -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Width="44" Height="44" CornerRadius="12"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Margin="0,0,14,0">
                                <iconPacks:PackIconMaterial Kind="Lock" FontSize="20"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Iniciar Sesión"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="Ingresá tus credenciales"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Separador sutil -->
                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,20,0,0" />

                        <!-- ========== CAMPO: USUARIO ========== -->
                        <TextBlock Text="Usuario"
                                   Style="{StaticResource LabelStyle}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,20,0,6" />

                        <Border Style="{StaticResource InputIconContainerStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <iconPacks:PackIconMaterial Grid.Column="0"
                                                                      Kind="Account"
                                                                      FontSize="16"
                                                                      VerticalAlignment="Center"
                                                                      Margin="14,0,10,0"
                                                                      Opacity="0.5" />

                                <TextBox Grid.Column="1"
                                         Text="{Binding Username}"
                                         Style="{StaticResource IconInputStyle}"
                                         x:Name="UsernameBox"
                                         ToolTip="Ej: admin123"
                                         VerticalAlignment="Stretch" />

                                <Border Grid.Column="2"
                                        x:Name="UsernameFocusIndicator"
                                        Width="3"
                                        Background="{DynamicResource PrimaryBrush}"
                                        CornerRadius="0,6,6,0"
                                        Margin="0"
                                        Opacity="0" />
                            </Grid>
                        </Border>

                        <!-- ========== CAMPO: CONTRASEÑA ========== -->
                        <TextBlock Text="Contraseña"
                                   Style="{StaticResource LabelStyle}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,16,0,6" />

                        <Border Style="{StaticResource InputIconContainerStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <iconPacks:PackIconMaterial Grid.Column="0"
                                                                      Kind="Lock"
                                                                      FontSize="16"
                                                                      VerticalAlignment="Center"
                                                                      Margin="14,0,10,0"
                                                                      Opacity="0.5" />

                                <PasswordBox Grid.Column="1"
                                              x:Name="PasswordBox"
                                              Style="{StaticResource IconPasswordInputStyle}"
                                              VerticalAlignment="Stretch"
                                              controls:PasswordBoxHelper.IsMonitoring="True"
                                              controls:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              controls:PasswordBoxHelper.SecurePassword="{Binding SecurePassword, Mode=OneWayToSource}"
                                              Visibility="{Binding ShowPassword, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                                <TextBox Grid.Column="1"
                                         x:Name="PasswordVisibleBox"
                                         Text="{Binding Password}"
                                         Style="{StaticResource IconInputStyle}"
                                         VerticalAlignment="Stretch"
                                         Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <ToggleButton Grid.Column="2"
                                              x:Name="TogglePasswordBtn"
                                              IsChecked="{Binding ShowPassword}"
                                              Style="{StaticResource TogglePasswordButtonStyle}"
                                              Width="40"
                                              Height="40"
                                              Margin="0,0,4,0"
                                              ToolTipService.ToolTip="Mostrar contraseña" />
                            </Grid>
                        </Border>

                        <!-- ========== MENSAJE DE ERROR con animación ========== -->
                        <Border Height="40"
                                Margin="0,4,0,0"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource ErrorFadeInAnimation}" />
                                </EventTrigger>
                            </Border.Triggers>
                            <Border Background="{DynamicResource AlertDangerBgBrush}"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Height="36"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Grid.Column="0" Kind="Alert" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource DangerBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ErrorMessage}"
                                               FontSize="12"
                                               Foreground="{DynamicResource DangerBrush}"
                                               VerticalAlignment="Center"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </Border>

                        <!-- ========== BOTÓN INGRESAR ========== -->
                        <Button Content="INGRESAR"
                                Command="{Binding LoginCommand}"
                                Style="{StaticResource PremiumActionButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Height="48"
                                Margin="0,12,0,0"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                        <!-- ========== LOADING ========== -->
                        <ProgressBar IsIndeterminate="True"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                                     Margin="0,16,0,0"
                                     Height="4"
                                     Foreground="{DynamicResource PrimaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
</file>

<file path="src/SistemaGVP.WPF/Views/LoginView.xaml.cs">
using System.Windows;
using System.Windows.Controls;
using System.Windows.Controls.Primitives;
using System.Windows.Input;
using SistemaGVP.WPF.ViewModels;

namespace SistemaGVP.WPF.Views;

public partial class LoginView : UserControl
{
    private readonly LoginViewModel _viewModel;

    public LoginView(LoginViewModel viewModel)
    {
        InitializeComponent();
        _viewModel = viewModel;
        DataContext = viewModel;

        PasswordBox.KeyDown += (sender, args) =>
        {
            if (args.Key == Key.Enter)
                _viewModel.LoginCommand.Execute(null);
        };

        PasswordVisibleBox.KeyDown += (sender, args) =>
        {
            if (args.Key == Key.Enter)
                _viewModel.LoginCommand.Execute(null);
        };

        TogglePasswordBtn.Checked += (_, _) =>
        {
            PasswordVisibleBox.Focus();
        };

        TogglePasswordBtn.Unchecked += (_, _) =>
        {
            PasswordBox.Focus();
        };

        _viewModel.PropertyChanged += (_, e) =>
        {
            if (e.PropertyName == nameof(LoginViewModel.ShowPassword))
                UpdateToggleButtonContent();
        };
        UpdateToggleButtonContent();

        UsernameBox.KeyDown += (sender, args) =>
        {
            if (args.Key == Key.Enter)
                PasswordBox.Focus();
        };
    }

    private void UpdateToggleButtonContent()
    {
        if (_viewModel.ShowPassword)
        {
            TogglePasswordBtn.Content = new TextBlock
            {
                Text = "\U0001F648",
                FontSize = 16,
                HorizontalAlignment = HorizontalAlignment.Center,
                VerticalAlignment = VerticalAlignment.Center
            };
            TogglePasswordBtn.ToolTip = "Ocultar contraseña";
        }
        else
        {
            TogglePasswordBtn.Content = new TextBlock
            {
                Text = "\U0001F441\uFE0F",
                FontSize = 16,
                HorizontalAlignment = HorizontalAlignment.Center,
                VerticalAlignment = VerticalAlignment.Center
            };
            TogglePasswordBtn.ToolTip = "Mostrar contraseña";
        }
    }
}

<file path="src/SistemaGVP.WPF/Views/ReportsView.xaml">
<UserControl x:Class="SistemaGVP.WPF.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SistemaGVP.WPF.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dto="clr-namespace:SistemaGVP.Application.DTOs;assembly=SistemaGVP.Application"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ReportsViewModel}"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ========== CABECERA ========== -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource PrimaryBrush}">
                <TextBlock Text="&#x1F4C8;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="Reportes" Style="{StaticResource Heading2Style}" />
                <TextBlock Text="Genere y exporte reportes detallados del sistema" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- ========== PANEL DE FILTROS ========== -->
        <Border Grid.Row="1"
                Style="{StaticResource ToolbarStyle}"
                Padding="16,12"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <!-- Tipo de reporte -->
                <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                    <TextBlock Text="Tipo de Reporte"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding ReportTypes}"
                              SelectedItem="{Binding SelectedReportType}"
                              MinWidth="200"
                              Height="34"
                              FontSize="13" />
                </StackPanel>

                <!-- Fecha inicio -->
                <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                    <TextBlock Text="Fecha Inicio"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,4" />
                    <DatePicker SelectedDate="{Binding StartDate}"
                                Height="34"
                                Width="140"
                                FontSize="13" />
                </StackPanel>

                <!-- Fecha fin -->
                <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                    <TextBlock Text="Fecha Fin"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,4" />
                    <DatePicker SelectedDate="{Binding EndDate}"
                                Height="34"
                                Width="140"
                                FontSize="13" />
                </StackPanel>

                <!-- Botón Generar -->
                <Button Content="🔍 Generar"
                        Command="{Binding GenerateReportCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="34"
                        Padding="20,0"
                        Margin="0,20,8,0"
                        ToolTipService.ToolTip="Generar el reporte seleccionado" />

                <!-- Botón Excel -->
                <Button Content="📊 Excel"
                        Command="{Binding ExportToExcelCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="34"
                        Padding="16,0"
                        Margin="0,20,8,0"
                        ToolTipService.ToolTip="Exportar a Excel" />

                <!-- Botón PDF -->
                <Button Content="📄 PDF"
                        Command="{Binding ExportToPdfCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="34"
                        Padding="16,0"
                        Margin="0,20,0,0"
                        ToolTipService.ToolTip="Exportar a PDF" />
            </StackPanel>
        </Border>

        <!-- ========== MENSAJES DE ESTADO ========== -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8" VerticalAlignment="Top">
            <TextBlock Text="{Binding StatusMessage}"
                       Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                       FontSize="13"
                       Foreground="{DynamicResource SuccessBrush}" />
            <TextBlock Text="{Binding ErrorMessage}"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                       FontSize="13"
                       Foreground="{DynamicResource DangerBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- ========== CONTENEDOR DE DATAGRIDS ========== -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,8">
        <Grid Margin="0,0,0,0">

            <!-- ── DataGrid 1: Ventas Diarias (DailySalesSummaryDto) ── -->
            <DataGrid ItemsSource="{Binding DailySales}"
                      AutoGenerateColumns="False"
                      Visibility="{Binding IsDailySales, Converter={StaticResource BoolToVisibilityConverter}}"
                      AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                      AlternationCount="2"
                      Style="{StaticResource DataGridStyle}"
                      d:DataContext="{d:DesignInstance dto:DailySalesSummaryDto}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Total Ventas"
                                        Binding="{Binding TotalSales, StringFormat={}{0:N0}}"
                                        Width="*" />
                    <DataGridTextColumn Header="Ingresos Totales"
                                        Binding="{Binding TotalRevenue, Converter={StaticResource CurrencyConverter}}"
                                        Width="*" />
                    <DataGridTextColumn Header="Total Impuestos"
                                        Binding="{Binding TotalTax, Converter={StaticResource CurrencyConverter}}"
                                        Width="*" />
                    <DataGridTextColumn Header="Total Ítems"
                                        Binding="{Binding TotalItems, StringFormat={}{0:N0}}"
                                        Width="*" />
                    <DataGridTextColumn Header="Ticket Promedio"
                                        Binding="{Binding AverageTicket, Converter={StaticResource CurrencyConverter}}"
                                        Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── DataGrid 2: Productos Más Vendidos (TopProductDto) ── -->
            <DataGrid ItemsSource="{Binding TopProducts}"
                      AutoGenerateColumns="False"
                      Visibility="{Binding IsTopProducts, Converter={StaticResource BoolToVisibilityConverter}}"
                      AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                      AlternationCount="2"
                      Style="{StaticResource DataGridStyle}"
                      d:DataContext="{d:DesignInstance dto:TopProductDto}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto"
                                        Binding="{Binding ProductName}"
                                        Width="*" />
                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding Barcode}"
                                        Width="120" />
                    <DataGridTextColumn Header="Cantidad Vendida"
                                        Binding="{Binding TotalQuantity, StringFormat={}{0:N0}}"
                                        Width="140" />
                    <DataGridTextColumn Header="Ingresos"
                                        Binding="{Binding TotalRevenue, Converter={StaticResource CurrencyConverter}}"
                                        Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── DataGrid 3: Stock Bajo (LowStockProductDto) ── -->
            <DataGrid ItemsSource="{Binding LowStockItems}"
                      AutoGenerateColumns="False"
                      Visibility="{Binding IsLowStock, Converter={StaticResource BoolToVisibilityConverter}}"
                      AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                      AlternationCount="2"
                      Style="{StaticResource DataGridStyle}"
                      d:DataContext="{d:DesignInstance dto:LowStockProductDto}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto"
                                        Binding="{Binding ProductName}"
                                        Width="*" />
                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding Barcode}"
                                        Width="120" />
                    <DataGridTextColumn Header="Stock Actual"
                                        Binding="{Binding CurrentStock, StringFormat={}{0:N2}}"
                                        Width="120" />
                    <DataGridTextColumn Header="Stock Mínimo"
                                        Binding="{Binding MinStock, StringFormat={}{0:N2}}"
                                        Width="120" />
                    <DataGridTemplateColumn Header="Diferencia" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Difference, StringFormat={}{0:N2}}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           Foreground="{DynamicResource DangerBrush}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── DataGrid 4: Ventas por Período (SalesByPeriodDto) ── -->
            <DataGrid ItemsSource="{Binding SalesByPeriod}"
                      AutoGenerateColumns="False"
                      Visibility="{Binding IsSalesByPeriod, Converter={StaticResource BoolToVisibilityConverter}}"
                      AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                      AlternationCount="2"
                      Style="{StaticResource DataGridStyle}"
                      d:DataContext="{d:DesignInstance dto:SalesByPeriodDto}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fecha"
                                        Binding="{Binding Date, StringFormat={}{0:dd/MM/yyyy}}"
                                        Width="*" />
                    <DataGridTextColumn Header="Ventas"
                                        Binding="{Binding TotalSales, StringFormat={}{0:N0}}"
                                        Width="120" />
                    <DataGridTextColumn Header="Monto Total"
                                        Binding="{Binding TotalAmount, Converter={StaticResource CurrencyConverter}}"
                                        Width="*" />
                    <DataGridTextColumn Header="Cant. Ítems"
                                        Binding="{Binding ItemCount, StringFormat={}{0:N0}}"
                                        Width="120" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── DataGrid 5: Márgenes de Ganancia (ProfitMarginDto) ── -->
            <DataGrid ItemsSource="{Binding ProfitMargins}"
                      AutoGenerateColumns="False"
                      Visibility="{Binding IsProfitMargins, Converter={StaticResource BoolToVisibilityConverter}}"
                      AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                      AlternationCount="2"
                      Style="{StaticResource DataGridStyle}"
                      d:DataContext="{d:DesignInstance dto:ProfitMarginDto}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Período"
                                        Binding="{Binding Period}"
                                        Width="*" />
                    <DataGridTextColumn Header="Ingresos"
                                        Binding="{Binding TotalRevenue, Converter={StaticResource CurrencyConverter}}"
                                        Width="*" />
                    <DataGridTextColumn Header="Costos"
                                        Binding="{Binding TotalCost, Converter={StaticResource CurrencyConverter}}"
                                        Width="*" />
                    <DataGridTextColumn Header="Ganancia"
                                        Binding="{Binding Profit, Converter={StaticResource CurrencyConverter}}"
                                        Width="*" />
                    <DataGridTextColumn Header="Margen"
                                        Binding="{Binding Margin, StringFormat={}{0:P2}}"
                                        Width="120" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- ── DataGrid 6: Valoración de Inventario (InventoryValuationDto) ── -->
            <DataGrid ItemsSource="{Binding InventoryValuation}"
                      AutoGenerateColumns="False"
                      Visibility="{Binding IsInventoryValuation, Converter={StaticResource BoolToVisibilityConverter}}"
                      AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                      AlternationCount="2"
                      Style="{StaticResource DataGridStyle}"
                      d:DataContext="{d:DesignInstance dto:InventoryValuationDto}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto"
                                        Binding="{Binding ProductName}"
                                        Width="*" />
                    <DataGridTextColumn Header="Categoría"
                                        Binding="{Binding Category}"
                                        Width="*" />
                    <DataGridTextColumn Header="Stock Actual"
                                        Binding="{Binding CurrentStock, StringFormat={}{0:N2}}"
                                        Width="120" />
                    <DataGridTextColumn Header="Costo Unit."
                                        Binding="{Binding UnitCost, Converter={StaticResource CurrencyConverter}}"
                                        Width="120" />
                    <DataGridTextColumn Header="Valor Total"
                                        Binding="{Binding TotalValue, Converter={StaticResource CurrencyConverter}}"
                                        Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty state cuando no hay reporte seleccionado -->
            <TextBlock Text="Seleccione un tipo de reporte y presione Generar"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="15"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Visibility="{Binding IsDailySales, Converter={StaticResource InverseBoolConverter}}" />
        </Grid>
        </Border>

        <!-- ========== LOADING OVERLAY ========== -->
        <Border Grid.RowSpan="5"
                Background="{DynamicResource OverlayBgBrush}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="300"
                             Height="6"
                             Margin="0,0,0,12" />
                <TextBlock Text="Generando reporte..."
                           FontSize="14"
                           Foreground="{DynamicResource TextInverseBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
</file>

<file path="src/SistemaGVP.WPF/Views/ReportsView.xaml.cs">
using SistemaGVP.WPF.ViewModels;
using System.Windows.Controls;

namespace SistemaGVP.WPF.Views;

public partial class ReportsView : UserControl
{
    public ReportsView(ReportsViewModel viewModel)
    {
        InitializeComponent();
        DataContext = viewModel;


                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ClipboardText" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Inventario" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:NavigationViewItem.Content>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemHeader Text="OPERACIONES" />
                <ui:NavigationViewItem Command="{Binding NavigateToSuppliersCommand}" TargetPageTag="Suppliers">
                    <ui:NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Factory" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Proveedores" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:NavigationViewItem.Content>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Command="{Binding NavigateToReportsCommand}" TargetPageTag="Reports">
                    <ui:NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ChartLine" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Reportes" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:NavigationViewItem.Content>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemHeader Text="ADMINISTRACIÓN" />
                <ui:NavigationViewItem Command="{Binding NavigateToUsersCommand}" TargetPageTag="Users"
                                       Visibility="{Binding ShowUserManagement, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ui:NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Account" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Usuarios" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:NavigationViewItem.Content>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Command="{Binding NavigateToSettingsCommand}" TargetPageTag="Settings"
                                       Visibility="{Binding ShowUserManagement, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ui:NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Cog" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Configuración" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:NavigationViewItem.Content>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemHeader Text="SISTEMA" />
                <ui:NavigationViewItem Command="{Binding NavigateToBackupCommand}" TargetPageTag="Backup">
                    <ui:NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ContentSave" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Backup" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:NavigationViewItem.Content>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Command="{Binding NavigateToAuditLogCommand}" TargetPageTag="AuditLog"
                                       Visibility="{Binding ShowUserManagement, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ui:NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ClipboardText" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Auditoría" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:NavigationViewItem.Content>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.ContentOverlay>
                <ContentControl x:Name="MainContentArea"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch" />
            </ui:NavigationView.ContentOverlay>

            <ui:NavigationView.PaneFooter>
                <StackPanel Margin="12,12">
                    <TextBlock Text="Sistema GVP v2.0"

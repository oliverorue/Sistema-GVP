                                <TextBox Text="{Binding EditingCustomer.Email}" Style="{StaticResource PremiumTextBoxStyle}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="DirecciÃ³n" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingCustomer.Address}" Style="{StaticResource PremiumTextBoxStyle}"

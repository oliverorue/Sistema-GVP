                <TextBlock Text="Gestión de productos y stock" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
            <Button Content="➡ Nuevo Producto"
                    Command="{Binding NewProductCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Height="36" Margin="24,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <!-- ========== BARRA DE BÚSQUEDA Y ACCIONES ========== -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}" Padding="12,8"
                Margin="0,0,0,12">

<UserControl x:Class="SistemaGVP.WPF.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SistemaGVP.WPF.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:AuditLogViewModel}"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ========== CABECERA ========== -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource PrimaryBrush}">
                <TextBlock Text="&#x1F4CB;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="Registro de Auditoría" Style="{StaticResource Heading2Style}" />
                <TextBlock Text="Seguimiento de todas las operaciones del sistema" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- ========== FILTROS ========== -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarStyle}" Padding="16,12"
                Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Desde:" VerticalAlignment="Center"
                               FontSize="13" FontWeight="Medium" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}"
                                Width="140" Margin="0,0,16,0" />

                    <TextBlock Grid.Column="2" Text="Hasta:" VerticalAlignment="Center"
                               FontSize="13" FontWeight="Medium" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <DatePicker Grid.Column="3" SelectedDate="{Binding EndDate}"
                                Width="140" Margin="0,0,16,0" />

                    <TextBlock Grid.Column="4" Text="Acción:" VerticalAlignment="Center"
                               FontSize="13" FontWeight="Medium" Margin="0,0,8,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <ComboBox Grid.Column="5" ItemsSource="{x:Static vm:AuditLogViewModel.ActionOptions}"
                              SelectedItem="{Binding ActionFilter}" Width="140" Margin="0,0,8,0" />

                    <Button Grid.Column="6" Content="&#x1F50D; Filtrar"
                            Command="{Binding SearchCommand}"
                            Style="{DynamicResource PrimaryButtonStyle}" Height="32"
                            FontSize="12" Padding="12,4" />
                </Grid>
                <Grid>
                    <Button Content="&#x1F504; Limpiar filtros" Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Height="28"
                            FontSize="11" Padding="10,2" HorizontalAlignment="Left" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========== DATAGRID ========== -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
        <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                  AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                  AlternationCount="2"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}"
                                    Width="130" />
                <DataGridTextColumn Header="Usuario" Binding="{Binding UserName}" Width="120" />
                <DataGridTextColumn Header="Acción" Binding="{Binding ActionDisplay}" Width="120" />
                <DataGridTextColumn Header="Entidad" Binding="{Binding EntityNameDisplay}" Width="120" />
                <DataGridTextColumn Header="ID" Binding="{Binding EntityId}" Width="60" />
                <DataGridTextColumn Header="Resumen" Binding="{Binding Summary}" Width="*" />
                <DataGridTemplateColumn Header="Detalle" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="&#x1F50D;"
                                    Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonStyle}"
                                    FontSize="13" Padding="6,2" MinWidth="32"
                                    HorizontalAlignment="Center"
                                    ToolTipService.ToolTip="Ver detalle" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </Border>

        <!-- ========== PAGINACIÓN ========== -->
        <Border Grid.Row="3"
                Padding="14,10"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,12,12"
                Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="← Anterior"
                        Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="32" FontSize="12" Padding="12,4"
                        Visibility="{Binding HasPreviousPage, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding PaginationText}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
                <Button Grid.Column="2"
                        Content="Siguiente →"
                        Command="{Binding NextPageCommand}"
Style="{StaticResource PrimaryButtonStyle}"
                        Height="32" FontSize="12" Padding="12,4"
                        Visibility="{Binding HasNextPage, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Border>

        <!-- ========== OVERLAY DETALLE ========== -->
        <Border Grid.RowSpan="4"
                Visibility="{Binding IsViewingDetail, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="{DynamicResource OverlayBgBrush}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12" Padding="24"
                    MaxWidth="550">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="&#x1F50D; Detalle de Auditoría"
                                   Style="{StaticResource Heading2Style}" Margin="0,0,0,16" />

                        <TextBlock Text="Fecha" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding SelectedLog.CreatedAt, StringFormat=dd/MM/yyyy HH:mm:ss}"
                                   FontSize="14" Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock Text="Usuario" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding SelectedLog.UserName}"
                                   FontSize="14" Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock Text="Acción" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding SelectedLog.ActionDisplay}"
                                   FontSize="14" Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock Text="Entidad" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,2" />
                        <TextBlock FontSize="14" Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="{Binding SelectedLog.EntityNameDisplay}" />
                            <Run Text=" #" />
                            <Run Text="{Binding SelectedLog.EntityId}" />
                        </TextBlock>

                        <TextBlock Text="IP" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,2" />
                        <TextBlock Text="{Binding SelectedLog.IpAddress}"
                                   FontSize="14" Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <TextBlock Text="Valores Anteriores" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,2" />
                        <TextBox Text="{Binding SelectedLog.OldValues}" IsReadOnly="True"
                                 Style="{StaticResource PremiumTextBoxStyle}"
                                 Height="80" TextWrapping="Wrap" Margin="0,0,0,12" />

                        <TextBlock Text="Valores Nuevos" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,2" />
                        <TextBox Text="{Binding SelectedLog.NewValues}" IsReadOnly="True"
                                 Style="{StaticResource PremiumTextBoxStyle}"
                                 Height="80" TextWrapping="Wrap" Margin="0,0,0,16" />

                        <Button Content="&#x274C; Cerrar" Command="{Binding CloseDetailCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="38" MinWidth="120" HorizontalAlignment="Right" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>
</file>


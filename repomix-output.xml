<ui:ContentDialog x:Class="SistemaGVP.WPF.Views.Dialogs.PaymentDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                  Title="Cobrar Venta"
                  PrimaryButtonText="Confirmar pago"
                  CloseButtonText="Cancelar"
                  DialogMaxWidth="500">
    <StackPanel>
        <Border Background="{DynamicResource AlertSuccessBgBrush}"
                CornerRadius="12" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Total a pagar" Style="{StaticResource LabelStyle}" Foreground="{DynamicResource SuccessBrush}" />
                <TextBlock Text="{Binding Total, Converter={StaticResource CurrencyConverter}}"
                           FontSize="32" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" />
            </StackPanel>
        </Border>

        <TextBlock Style="{StaticResource CaptionStyle}" Margin="0,0,0,8">
            <Run Text="Cliente: " />
            <Run Text="{Binding SelectedCustomer.Name}" FontWeight="SemiBold" />
        </TextBlock>

        <TextBlock Text="Método de pago" Style="{StaticResource LabelStyle}" Margin="0,0,0,4" />
        <ComboBox ItemsSource="{Binding PaymentMethods}"
                  SelectedItem="{Binding SelectedPaymentMethod}"
                  Margin="0,0,0,12"
                  Height="36" FontSize="14" />

        <TextBlock Text="Monto recibido" Style="{StaticResource LabelStyle}" Margin="0,0,0,4" />

                    <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" FontWeight="SemiBold" Width="*" />
                    <DataGridTextColumn Header="Teléfono" Binding="{Binding Phone}" Width="130" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                    <DataGridTextColumn Header="DirecciÃ³n" Binding="{Binding Address}" Width="2*" />
                    <DataGridTemplateColumn Header="Acciones" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="âœï¸"
                                            Command="{Binding DataContext.EditCustomerCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}"
                                            FontSize="13" Padding="8,4" MinWidth="36"
                                            ToolTipService.ToolTip="Editar cliente" Margin="0,0,4,0" />
                                    <Button Content="ðŸ—‘ï¸"
                                            Command="{Binding DataContext.DeleteCustomerCommand, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}"
                                            FontSize="13" Padding="8,4" MinWidth="36"
                                            ToolTipService.ToolTip="Eliminar cliente" />

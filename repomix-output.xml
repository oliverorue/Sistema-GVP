                        </StackPanel>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                                   TextWrapping="Wrap" FontWeight="Medium" Margin="0,0,0,8" />

                        <TextBlock Text="Nombre" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding EditingCustomer.Name}" Style="{StaticResource PremiumTextBoxStyle}" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="TelÃ©fono" FontSize="13" FontWeight="Medium"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditingCustomer.Phone}" Style="{StaticResource PremiumTextBoxStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Email" FontSize="13" FontWeight="Medium"

                    <ui:NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Cart" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Punto de Venta" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:NavigationViewItem.Content>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Command="{Binding NavigateToSalesHistoryCommand}" TargetPageTag="SalesHistory">
                    <ui:NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Receipt" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Historial de Ventas" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:NavigationViewItem.Content>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemHeader Text="GESTIÓN" />
                <ui:NavigationViewItem Command="{Binding NavigateToProductsCommand}" TargetPageTag="Products">
                    <ui:NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="PackageVariant" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Productos" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:NavigationViewItem.Content>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Command="{Binding NavigateToCategoriesCommand}" TargetPageTag="Categories">
                    <ui:NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Folder" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Categorías" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:NavigationViewItem.Content>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Command="{Binding NavigateToCustomersCommand}" TargetPageTag="Customers">
                    <ui:NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal">

<file path="src/SistemaGVP.WPF/Views/DashboardView.xaml">
<UserControl x:Class="SistemaGVP.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:vm="clr-namespace:SistemaGVP.WPF.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <!-- ============================================================
             ERROR BANNER (D1)
             ============================================================ -->
        <Border Panel.ZIndex="5"
                Visibility="{Binding HasErrors, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="{DynamicResource AlertDangerBgBrush}"
                BorderBrush="{DynamicResource DangerBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16,12"
                Margin="32,12,32,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <iconPacks:PackIconMaterial Grid.Column="0" Kind="Alert" FontSize="18" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{DynamicResource DangerBrush}" />
                <ItemsControl Grid.Column="1" ItemsSource="{Binding LoadErrors}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" Foreground="{DynamicResource DangerBrush}"
                                       TextWrapping="Wrap" Margin="0,1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- ============================================================
             SKELETON LOADING OVERLAY
             ============================================================ -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="{DynamicResource BackgroundBrush}"
              Panel.ZIndex="4"
              Margin="32,24,32,32">
            <StackPanel>
                <!-- Skeleton: welcome -->
                <Border Style="{StaticResource SkeletonBlockStyle}" Width="240" Height="28" Margin="0,0,0,8"
                        HorizontalAlignment="Left" />
                <Border Style="{StaticResource SkeletonBlockStyle}" Width="180" Height="16" Margin="0,0,0,24"
                        HorizontalAlignment="Left" />
                <!-- Skeleton: 4 metric cards -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="12" Margin="0,0,6,0" Height="100" />
                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="12" Margin="6,0" Height="100" />
                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="12" Margin="6,0" Height="100" />
                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="12" Margin="6,0,0,0" Height="100" />
                </Grid>
                <!-- Skeleton: chart area -->
                <Border Style="{StaticResource MetricCardStyle}" Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="12" Height="280" Margin="0,0,0,16" />
                <!-- Skeleton: 2 columns -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="12" Margin="0,0,8,0" Height="200" />
                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="12" Margin="8,0,0,0" Height="200" />
                </Grid>
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,24,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ============================================================
                     ROW 0: WELCOME HEADER
                     ============================================================ -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                    <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource PrimaryBrush}">
                        <iconPacks:PackIconMaterial Kind="ChartBar" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="{Binding WelcomeMessage}" Style="{StaticResource Heading2Style}" />
                        <TextBlock Text="{Binding CompanyName}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- ============================================================
                     ROW 1: METRIC CARDS (4 columns)
                     ============================================================ -->
                <Grid Grid.Row="1" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Products -->
                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}"
                            Background="{DynamicResource CardBlueBrush}"
                            BorderBrush="{DynamicResource CardBlueBrush}"
                            BorderThickness="1"
                            Margin="0,0,6,0">
                        <Grid>
                            <iconPacks:PackIconMaterial Kind="PackageVariant" FontSize="48" Opacity="0.12"
                                                      Foreground="{DynamicResource TextInverseBrush}"
                                                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                      Margin="0,0,8,4" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Productos" Style="{StaticResource MetricLabel}"
                                           Foreground="{DynamicResource TextInverseBrush}" Opacity="0.75" Margin="0,0,0,12" />
                                <TextBlock Text="{Binding TotalProducts}" Style="{StaticResource MetricValue}"
                                           Foreground="{DynamicResource TextInverseBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Categories -->
                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}"
                            Background="{DynamicResource CardTealBrush}"
                            BorderBrush="{DynamicResource CardTealBrush}"
                            BorderThickness="1"
                            Margin="6,0">
                        <Grid>
                            <iconPacks:PackIconMaterial Kind="Folder" FontSize="48" Opacity="0.12"
                                                      Foreground="{DynamicResource TextInverseBrush}"
                                                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                      Margin="0,0,8,4" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Categorías" Style="{StaticResource MetricLabel}"
                                           Foreground="{DynamicResource TextInverseBrush}" Opacity="0.75" Margin="0,0,0,12" />
                                <TextBlock Text="{Binding TotalCategories}" Style="{StaticResource MetricValue}"
                                           Foreground="{DynamicResource TextInverseBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Customers -->
                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}"
                            Background="{DynamicResource CardGreenBrush}"
                            BorderBrush="{DynamicResource CardGreenBrush}"
                            BorderThickness="1"
                            Margin="6,0">
                        <Grid>
                            <iconPacks:PackIconMaterial Kind="AccountGroup" FontSize="48" Opacity="0.12"
                                                      Foreground="{DynamicResource TextInverseBrush}"
                                                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                      Margin="0,0,8,4" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Clientes" Style="{StaticResource MetricLabel}"
                                           Foreground="{DynamicResource TextInverseBrush}" Opacity="0.75" Margin="0,0,0,12" />
                                <TextBlock Text="{Binding TotalCustomers}" Style="{StaticResource MetricValue}"
                                           Foreground="{DynamicResource TextInverseBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Today's Sales -->
                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}"
                            Background="{DynamicResource CardOrangeBrush}"
                            BorderBrush="{DynamicResource CardOrangeBrush}"
                            BorderThickness="1"
                            Margin="6,0,0,0">
                        <Grid>
                            <iconPacks:PackIconMaterial Kind="Cash" FontSize="48" Opacity="0.12"
                                                      Foreground="{DynamicResource TextInverseBrush}"
                                                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                      Margin="0,0,8,4" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Ventas Hoy" Style="{StaticResource MetricLabel}"
                                           Foreground="{DynamicResource TextInverseBrush}" Opacity="0.75" Margin="0,0,0,12" />
                                <TextBlock Text="{Binding TodaySalesCount}" Style="{StaticResource MetricValue}"
                                           Foreground="{DynamicResource TextInverseBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ============================================================
                     ROW 2: LOW STOCK ALERT
                     ============================================================ -->
                <Border Grid.Row="2"
                        Background="{DynamicResource AlertDangerBgBrush}"
                        BorderBrush="{DynamicResource DangerBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="20,16"
                        Margin="0,0,0,20"
                        Visibility="{Binding HasLowStock, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <iconPacks:PackIconMaterial Grid.Column="0"
                                                       Kind="Alert"
                                                       FontSize="24"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,16,0"
                                                       Foreground="{DynamicResource DangerBrush}" />
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding LowStockCount, StringFormat='{}{0} producto(s) con stock crítico'}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DangerBrush}"
                                       TextTrimming="None" />
                            <TextBlock Text="Revisá el inventario para reabastecer"
                                       FontSize="12"
                                       Foreground="{DynamicResource DangerBrush}"
                                       Opacity="0.8"
                                       TextTrimming="None"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="13"
                                Height="36"
                                Padding="16,8"
                                VerticalAlignment="Center"
                                Command="{Binding NavigateToInventoryCommand}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="PackageVariant" FontSize="14" Margin="0,0,6,0" />
                                <TextBlock Text="Ir a Inventario" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- ============================================================
                     ROW 3: WEEKLY SALES TREND — LiveCharts2 Line Chart
                     ============================================================ -->
                <Border Grid.Row="3"
                        Style="{StaticResource MetricCardStyle}"
                        Background="{DynamicResource SurfaceBrush}"
                        Padding="20"
                        Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <iconPacks:PackIconMaterial Kind="ChartLine" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Tendencia Semanal" Style="{StaticResource Heading3Style}" VerticalAlignment="Center" />
                        </StackPanel>

                        <lvc:CartesianChart Grid.Row="1"
                                            Series="{Binding WeeklySalesSeries}"
                                            XAxes="{Binding WeeklySalesXAxes}"
                                            YAxes="{Binding WeeklySalesYAxes}"
                                            MinHeight="280"
                                            Visibility="{Binding HasWeeklySales, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <!-- Empty state when no weekly data -->
                        <Border Grid.Row="1"
                                Visibility="{Binding HasWeeklySales, Converter={StaticResource InverseBoolConverter}}"
                                VerticalAlignment="Center"
                                MinHeight="280">
                            <Border Style="{StaticResource EmptyStateStyle}">
                                <StackPanel>
                                    <iconPacks:PackIconMaterial Kind="ChartBar" Style="{StaticResource EmptyStateIcon}" />
                                    <TextBlock Text="Sin datos de la última semana"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </Border>
                    </Grid>
                </Border>

                <!-- ============================================================
                     ROW 4: DAILY SUMMARY + TOP PRODUCTS (2 columns)
                     ============================================================ -->
                <Grid Grid.Row="4" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- ═══════════ Left: Daily Summary ═══════════ -->
                    <Border Grid.Column="0"
                            Style="{StaticResource MetricCardStyle}"
                            Background="{DynamicResource SurfaceBrush}"
                            Padding="20"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <iconPacks:PackIconMaterial Kind="Cash" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="Resumen del Día" Style="{StaticResource Heading3Style}" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Revenue row -->
                            <Grid Height="32" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="32" Height="32" CornerRadius="8"
                                        Background="{DynamicResource AlertInfoBgBrush}">
                                    <iconPacks:PackIconMaterial Kind="CurrencyUsd" FontSize="15"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="Ingresos Totales"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Margin="12,0,0,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DailyRevenue}"
                                           Style="{StaticResource PriceDisplay}"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- Average ticket row -->
                            <Grid Height="32" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="32" Height="32" CornerRadius="8"
                                        Background="{DynamicResource AlertSuccessBgBrush}">
                                    <iconPacks:PackIconMaterial Kind="Receipt" FontSize="15"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="Ticket Promedio"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Margin="12,0,0,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DailyAverageTicket}"
                                           Style="{StaticResource PriceDisplay}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- Items sold row -->
                            <Grid Height="32" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="32" Height="32" CornerRadius="8"
                                        Background="{DynamicResource AlertDangerBgBrush}">
                                    <iconPacks:PackIconMaterial Kind="PackageVariant" FontSize="15"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="Items Vendidos"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Margin="12,0,0,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DailyItemsSold}"
                                           Style="{StaticResource BodyStyle}"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- Tax row -->
                            <Grid Height="32" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="32" Height="32" CornerRadius="8"
                                        Background="{DynamicResource AlertWarningBgBrush}">
                                    <iconPacks:PackIconMaterial Kind="Bank" FontSize="15"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="Impuestos"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" Margin="12,0,0,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DailyTax}"
                                           Style="{StaticResource BodyStyle}"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- Separator -->
                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,8" />

                            <!-- Yesterday Comparison -->
                            <Grid Height="32">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="32" Height="32" CornerRadius="8"
                                        Background="{DynamicResource CardPurpleBrush}" Opacity="0.15">
                                    <iconPacks:PackIconMaterial Kind="ChartBar" FontSize="15"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="vs. Ayer"
                                           Style="{StaticResource BodySmallStyle}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="12,0,0,0" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SalesComparison}"
                                               Style="{StaticResource BodyStyle}"
                                               FontWeight="Bold"
                                               Foreground="{Binding SalesUp, Converter={StaticResource BoolToColorConverter}, ConverterParameter=greenRed}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding YesterdaySalesAmount, StringFormat='({0})'}"
                                               Style="{StaticResource CaptionStyle}"
                                               VerticalAlignment="Center" Margin="6,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ Right: Top Products Bar Chart ═══════════ -->
                    <Border Grid.Column="1"
                            Style="{StaticResource MetricCardStyle}"
                            Background="{DynamicResource SurfaceBrush}"
                            Padding="20"
                            Margin="8,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <iconPacks:PackIconMaterial Kind="Trophy" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="Productos Más Vendidos" Style="{StaticResource Heading3Style}" VerticalAlignment="Center" />
                            </StackPanel>

                            <lvc:CartesianChart Grid.Row="1"
                                                Series="{Binding TopProductsSeries}"
                                                XAxes="{Binding TopProductsXAxes}"
                                                YAxes="{Binding TopProductsYAxes}"
                                                MinHeight="280"
                                                Visibility="{Binding HasTopProducts, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <!-- Empty state -->
                            <Border Grid.Row="1"
                                    Visibility="{Binding HasTopProducts, Converter={StaticResource InverseBoolConverter}}"
                                    VerticalAlignment="Center"
                                    MinHeight="280">
                                <Border Style="{StaticResource EmptyStateStyle}">
                                    <StackPanel>
                                        <iconPacks:PackIconMaterial Kind="Tag" Style="{StaticResource EmptyStateIcon}" />
                                        <TextBlock Text="Sin datos de ventas aún"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ============================================================
                     ROW 5: PROFIT MARGIN + TODAY AMOUNT + QUICK ACTIONS
                     ============================================================ -->
                <Grid Grid.Row="5" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- ═══════════ Left: Profit Margin ═══════════ -->
                    <Border Grid.Column="0"
                            Style="{StaticResource MetricCardStyle}"
                            Background="{DynamicResource AlertSuccessBgBrush}"
                            Padding="24"
                            Margin="0,0,8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ChartBar" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource SuccessBrush}" Opacity="0.8" />
                                    <TextBlock Text="Margen del Día" Style="{StaticResource LabelStyle}"
                                           Foreground="{DynamicResource SuccessBrush}" Opacity="0.8"
                                           Margin="0,0,0,6" />
                                </StackPanel>
                                <TextBlock Text="{Binding ProfitMargin}"
                                           Style="{StaticResource MetricValue}"
                                           Foreground="{DynamicResource SuccessBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="Ganancia Bruta"
                                           Style="{StaticResource CaptionStyle}"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding ProfitAmount}"
                                           Style="{StaticResource PriceDisplay}"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ═══════════ Right: Today's Amount + Quick Actions ═══════════ -->
                    <Border Grid.Column="1"
                            Style="{StaticResource MetricCardStyle}"
                            Background="{DynamicResource SurfaceBrush}"
                            Padding="24"
                            Margin="8,0,0,0">
                        <StackPanel>
                            <!-- Today's amount -->
                            <StackPanel Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Cash" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource TextMutedBrush}" />
                                    <TextBlock Text="Ventas de Hoy" Style="{StaticResource LabelStyle}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,0,0,6" />
                                </StackPanel>
                                <TextBlock Text="{Binding TodaySalesAmount}"
                                           Style="{StaticResource MetricValue}"
                                           Foreground="{DynamicResource PrimaryBrush}" />
                            </StackPanel>

                            <!-- Separator -->
                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,16" />

                            <!-- Quick Actions -->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="LightningBolt" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <TextBlock Text="Acciones Rápidas" Style="{StaticResource LabelStyle}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,8" />
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            FontSize="12"
                                            Padding="12,8"
                                            Margin="0,0,4,0"
                                            Command="{Binding NavigateToProductsCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="Plus" FontSize="12" Margin="0,0,4,0" />
                                            <TextBlock Text="Nuevo Producto" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            FontSize="12"
                                            Padding="12,8"
                                            Margin="4,0,0,0"
                                            Command="{Binding NavigateToInventoryCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="PackageVariant" FontSize="12" Margin="0,0,4,0" />
                                            <TextBlock Text="Ajustar Stock" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
</file>


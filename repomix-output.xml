<file path="src/SistemaGVP.WPF/Styles/ModernBaseStyles.xaml">
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <!-- ======================================================================
         MODERN BASE STYLES — Sistema GVP
         
         NOTA: Todos los brushes usan {DynamicResource} para compatibilidad
         con el switch de tema claro/oscuro en runtime.
         Los brushes se definen en DarkTheme.xaml / LightTheme.xaml.
         ====================================================================== -->

    <!-- ===================== TYPOGRAPHY ===================== -->

    <Style x:Key="Heading1Style" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="Heading2Style" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="Heading3Style" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>


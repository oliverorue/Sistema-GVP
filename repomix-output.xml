<file path="src/SistemaGVP.WPF/Views/InventoryView.xaml">
<UserControl x:Class="SistemaGVP.WPF.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SistemaGVP.WPF.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:InventoryViewModel}"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">

        <!-- ===== CONTENIDO PRINCIPAL ===== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsAdjustOpen, Converter={StaticResource InverseBoolConverter}, ConverterParameter=True, FallbackValue=Visible}">
            <StackPanel>

                <!-- ========== CABECERA ========== -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource PrimaryBrush}">
                        <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="Inventario" Style="{StaticResource Heading2Style}" />
                        <TextBlock Text="Control de stock y movimientos" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                </StackPanel>
                <Border Style="{StaticResource ToolbarStyle}" Padding="12,8"
                        Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="🔍 Buscar"
                                Command="{Binding SearchCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="32"
                                Margin="0,0,8,0" />
                        <Button Content="🔄 Refrescar"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="32" />
                    </StackPanel>
                </Border>

                <!-- ========== PRODUCTOS CON STOCK BAJO ========== -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="&#x26A0;&#xFE0F; Productos con Stock Bajo"
                               Style="{StaticResource Heading3Style}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="{Binding LowStockCountText}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="13"
                               Margin="0,0,0,8" />
                </StackPanel>

                <!-- DataGrid: Stock bajo -->
                <DataGrid ItemsSource="{Binding LowStockItems}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MaxHeight="300"
                          Height="250"
                          Margin="0,0,0,24"
                          AlternatingRowBackground="{DynamicResource DataGridRowAltBrush}"
                          AlternationCount="2"
                          Style="{StaticResource DataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Producto"
                                            Binding="{Binding Name}"
                                            Width="*" />
                        <DataGridTextColumn Header="Código"
                                            Binding="{Binding Barcode}"
                                            Width="130" />
                        <DataGridTextColumn Header="Categoría"
                                            Binding="{Binding CategoryName}"
                                            Width="130" />
                        <DataGridTemplateColumn Header="Stock Actual" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                        <ProgressBar Value="{Binding CurrentStock}"
                                                     Maximum="{Binding MinStock}"
                                                     Width="80" Height="14"
                                                     Margin="0,0,8,0"
                                                     Style="{StaticResource StockProgressBarStyle}" />
                                        <TextBlock Text="{Binding CurrentStock}"
                                                   FontSize="12" FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding CurrentStock, Converter={StaticResource StockToColorConverter}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Stock Mínimo"
                                            Binding="{Binding MinStock}"
                                            Width="100"
                                            ElementStyle="{StaticResource RightAlignStyle}" />
                        <DataGridTemplateColumn Header="Acciones" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="⚙️ Ajustar"
                                            Command="{Binding DataContext.OpenAdjustCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SmallButtonStyle}"
                                            Margin="2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ========== SECCIÓN INFERIOR: MOVIMIENTOS RECIENTES ========== -->
                <TextBlock Text="📋 Movimientos de Inventario"
                           Style="{StaticResource Heading2Style}"
                           Margin="0,0,0,8" />

                <!-- DataGrid: Movimientos -->
                <DataGrid ItemsSource="{Binding RecentMovements}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MaxHeight="400"
                          Style="{StaticResource DataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha"
                                            Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                            Width="140" />
                        <DataGridTextColumn Header="Producto"
                                            Binding="{Binding ProductName}"
                                            Width="*" />
                        <DataGridTextColumn Header="Tipo"
                                            Binding="{Binding Type}"
                                            Width="100" />
                        <DataGridTextColumn Header="Cantidad"
                                            Binding="{Binding Quantity}"
                                            Width="80"
                                            ElementStyle="{StaticResource RightAlignStyle}" />
                        <DataGridTextColumn Header="Motivo"
                                            Binding="{Binding Reason}"
                                            Width="200" />
                        <DataGridTextColumn Header="Usuario"
                                            Binding="{Binding UserName}"
                                            Width="120" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Paginación -->
                <Grid Margin="0,8,0,0" Visibility="{Binding HasMovements, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="◀ Anterior"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding HasPreviousPage}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="32"
                            Margin="0,0,8,0" />

                    <TextBlock Grid.Column="1"
                               Text="{Binding PageInfo}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="14" />

                    <Button Grid.Column="2"
                            Content="Siguiente ▶"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding HasNextPage}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="32"
                            Margin="8,0,0,0" />
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== LOADING OVERLAY ===== -->
        <Grid Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="{DynamicResource OverlayBgBrush}"
              Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="300"
                             Height="20" />
                <TextBlock Text="Procesando..."
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>
        </Grid>

        <!-- ===== PANEL DE AJUSTE (OVERLAY) ===== -->
        <Grid Visibility="{Binding IsAdjustOpen, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="{DynamicResource OverlayBgBrush}"
              Panel.ZIndex="20">
            <Border Background="{DynamicResource SurfaceBrush}"
                    Width="450"
                    Padding="24"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15"
                                      Color="{DynamicResource TextPrimaryColor}" />
                </Border.Effect>
                <StackPanel>

                    <!-- Header -->
                    <TextBlock Text="{Binding SelectedProduct.Name, StringFormat='Ajuste de Stock — {0}'}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,16" />

                    <!-- Tipo de ajuste (Entrada/Salida) -->
                    <TextBlock Text="Tipo de ajuste"
                               Style="{StaticResource LabelStyle}" />
                    <ComboBox ItemsSource="{Binding AdjustmentTypes}"
                              SelectedItem="{Binding AdjustmentType}"
                              Style="{StaticResource ComboBoxStyle}"
                              Margin="0,0,0,12" />

                    <!-- Cantidad -->
                    <TextBlock Text="Cantidad"
                               Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding AdjustmentQuantity}"
                             Style="{StaticResource TextBoxStyle}"
                             Margin="0,0,0,12" />

                    <!-- Motivo -->
                    <TextBlock Text="Motivo"
                               Style="{StaticResource LabelStyle}" />
                    <TextBox Text="{Binding AdjustmentReason}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="80"
                             Style="{StaticResource TextBoxStyle}"
                             Margin="0,0,0,16" />

                    <!-- Mensaje de error -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                               Foreground="{DynamicResource DangerBrush}"
                               FontSize="13"
                               Margin="0,0,0,8" />

                    <!-- Botones -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding StatusMessage}"
                                   Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="1"
                                Content="✕ Cancelar"
                                Command="{Binding CloseAdjustCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="36"
                                Width="120"
                                Margin="0,0,8,0" />

                        <Button Grid.Column="2"
                                Content="✓ Guardar"
                                Command="{Binding SaveAdjustmentCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="36"
                                Width="120" />
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
</file>


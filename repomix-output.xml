                    <!-- Contenido central: logo y descripción -->
                    <StackPanel Grid.Row="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="48,0">

                        <!-- Logo decorativo con glow -->
                        <Border Width="80" Height="80"
                                CornerRadius="20"
                                Background="#33FFFFFF"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,24">
                            <Border.Effect>
